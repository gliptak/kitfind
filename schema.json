{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/gliptak/kitfind/main/schema.json",
  "title": "Kitfind index",
  "description": "Search blob for the Kitfind skill index — generated by tools/build.py",
  "type": "object",
  "required": ["version", "generated_at", "catalog", "skills"],
  "properties": {
    "version": {
      "type": "integer",
      "enum": [1],
      "description": "Blob format version"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of generation"
    },
    "catalog": {
      "type": "object",
      "required": ["sources", "stats"],
      "properties": {
        "sources": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["url", "ref", "fetched_at", "commit", "skill_count"],
            "properties": {
              "url": { "type": "string", "format": "uri" },
              "ref": { "type": "string" },
              "description": { "type": "string" },
              "fetched_at": { "type": "string", "format": "date-time" },
              "commit": { "type": "string" },
              "skill_count": { "type": "integer" }
            }
          }
        },
        "stats": {
          "type": "object",
          "required": ["total_skills", "total_sources", "by_domain"],
          "properties": {
            "total_skills": { "type": "integer" },
            "total_sources": { "type": "integer" },
            "by_domain": { "type": "object" },
            "generated_at": { "type": "string" }
          }
        }
      }
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "source", "description"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "source": {
            "type": "object",
            "required": ["url", "ref", "path"],
            "properties": {
              "url": { "type": "string" },
              "ref": { "type": "string" },
              "path": { "type": "string" }
            }
          },
          "description": { "type": "string" },
          "triggers": { "type": "array", "items": { "type": "string" } },
          "harnesses": { "type": "array", "items": { "type": "string" } },
          "domain": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "risk": { "type": "string" },
          "install_hint": { "type": "string" }
        }
      }
    }
  }
}
